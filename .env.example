# Required: Anthropic API key for Claude AI features
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Server
PORT=5000
NODE_ENV=development

# Claude model settings (optional)
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_TEMPERATURE=0.7

# Whop integration (required for production)
WHOP_CLIENT_ID=your_whop_client_id
WHOP_CLIENT_SECRET=your_whop_client_secret
WHOP_API_KEY=your_whop_api_key
WHOP_APP_ID=your_whop_app_id
WHOP_REDIRECT_URI=https://your-domain.com/auth/callback

# Development settings
ALLOW_DEV_TOKEN=true
DEFAULT_SUBSCRIPTION_TIER=pro

# CORS (optional, defaults to *)
CORS_ORIGIN=*

# Frontend (optional, set in production)
VITE_API_URL=/api
