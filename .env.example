# Anthropic AI (required)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-sonnet-4-20250514
CLAUDE_TEMPERATURE=0.7

# Server
PORT=5000
NODE_ENV=development
CORS_ORIGIN=*

# Whop Integration (optional - dev mode used if unset)
WHOP_API_KEY=
WHOP_APP_ID=
WHOP_CLIENT_ID=
WHOP_CLIENT_SECRET=
WHOP_REDIRECT_URI=

# Dev mode (set to false in production)
ALLOW_DEV_TOKEN=true
DEFAULT_SUBSCRIPTION_TIER=pro

# Frontend (optional)
VITE_API_URL=/api
